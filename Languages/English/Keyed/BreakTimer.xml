  <BreakTimer.HistoryEntryCause>{0} ({1}) - ended {2} ago, lasted {3}</BreakTimer.HistoryEntryCause>
  <BreakTimer.CauseMood>mood</BreakTimer.CauseMood>
  <BreakTimer.CauseDamage>damage</BreakTimer.CauseDamage>
  <BreakTimer.CausePsycast>psycast</BreakTimer.CausePsycast>

  <!-- Expanded view. Blocked-breaks section. {0} = intensity -->
  <BreakTimer.BlockedHeader>Blocked ({0}):</BreakTimer.BlockedHeader>
  <!-- {0} = label, {1} = reason -->
  <BreakTimer.BlockedEntry>{0}: {1}</BreakTimer.BlockedEntry>
  <BreakTimer.NoTierActive>Mood stable - no break tier active.</BreakTimer.NoTierActive>

  <!-- Expanded-view hint shown on the unexpanded tooltip. -->
  <BreakTimer.ShiftForMore>(hold Shift for details)</BreakTimer.ShiftForMore>

