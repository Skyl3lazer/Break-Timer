<?xml version="1.0" encoding="utf-8"?>
<LanguageData>

  <!-- Tooltip header / fallbacks -->
  <BreakTimer.NoPawnSelected>(no pawn selected)</BreakTimer.NoPawnSelected>
  <BreakTimer.TooltipError>Break Timer: error building tooltip (see log).</BreakTimer.TooltipError>
  <!-- {0} = break label -->
  <BreakTimer.Break>Break: {0}</BreakTimer.Break>

  <!-- Date line labels (a ":" is appended in code, followed by the date on the next line) -->
  <BreakTimer.Started>Started</BreakTimer.Started>
  <BreakTimer.Ends>Ends</BreakTimer.Ends>

  <!-- Remaining time. {0}/{1} = whole hours -->
  <BreakTimer.Remaining>Remaining: {0}h</BreakTimer.Remaining>
  <BreakTimer.RemainingPlus>Remaining: {0}h+</BreakTimer.RemainingPlus>
  <BreakTimer.RemainingRange>Remaining: {0}h - {1}h</BreakTimer.RemainingRange>

  <!-- End-time block -->
  <BreakTimer.EndsAfter>Ends after:</BreakTimer.EndsAfter>
  <BreakTimer.NoFixedEnd>(no fixed end)</BreakTimer.NoFixedEnd>
  <BreakTimer.EndsBetween>Ends between:</BreakTimer.EndsBetween>
  <!-- {0} = formatted date; trailing spaces in Latest align it under Earliest -->
  <BreakTimer.Earliest>Earliest: {0}</BreakTimer.Earliest>
  <BreakTimer.Latest>Latest:   {0}</BreakTimer.Latest>

  <!-- Possible-breaks preview. {0} = mood break intensity (Minor/Major/Extreme) -->
  <BreakTimer.PossibleBreaksNonePossible>Possible mental breaks:\n No possible breaks!</BreakTimer.PossibleBreaksNonePossible>
  <BreakTimer.PossibleBreaksBlocked>Possible mental breaks:\n Breaks are currently blocked!</BreakTimer.PossibleBreaksBlocked>
