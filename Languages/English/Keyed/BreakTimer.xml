  <BreakTimer.PossibleBreaksHeader>Possible mental breaks ({0}):</BreakTimer.PossibleBreaksHeader>
  <BreakTimer.AnomalySuffix>(anomaly)</BreakTimer.AnomalySuffix>

  <!-- Other potential states section. {0} = label, {1} = source, {2} = mean time between -->
  <BreakTimer.OtherStatesHeader>Other potential states:</BreakTimer.OtherStatesHeader>
  <BreakTimer.OtherStatesEntry>{0} ({1}) - every ~{2}</BreakTimer.OtherStatesEntry>

  <!-- Random break driven by a condition's mentalBreakMtbDays. {0} = allowed intensities (e.g. "minor/major") -->
  <BreakTimer.RandomHediffBreak>Random mental break</BreakTimer.RandomHediffBreak>
  <BreakTimer.RandomHediffBreakIntensity>Random {0} mental break</BreakTimer.RandomHediffBreakIntensity>

  <!-- Expanded view (Shift held). History section. -->
  <BreakTimer.HistoryHeader>Recent breaks:</BreakTimer.HistoryHeader>
  <!-- {0} = label, {1} = time ago, {2} = duration -->
  <BreakTimer.HistoryEntry>{0} - ended {1} ago, lasted {2}</BreakTimer.HistoryEntry>
