{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build BreakTimer (Release)",
      "type": "process",
      "command": "dotnet",
      "args": [
        "build",
        "Source/BreakTimer.csproj",
        "-c",
        "Release",
        "-nologo"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": "$msCompile"
    },
    {
      "label": "Build BreakTimer (Debug)",
      "type": "process",
      "command": "dotnet",
      "args": [
        "build",
        "Source/BreakTimer.csproj",
        "-c",
        "Debug",
        "-nologo"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": "$msCompile"
    }
  ]
}
